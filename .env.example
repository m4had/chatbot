# ============================================
# ULTRA CHATBOT - Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your keys.
# The app gracefully degrades when keys are missing.

# --- AI Model Providers (at least one required) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GENERATIVE_AI_API_KEY=AI...

# --- Primary model selection ---
# Options: openai/gpt-4o, anthropic/claude-sonnet-4-20250514, google/gemini-1.5-pro
PRIMARY_MODEL=openai/gpt-4o
FALLBACK_MODEL=anthropic/claude-sonnet-4-20250514

# --- RAG / Vector Search ---
# Uses local SQLite FTS5 by default (no external service needed)
# Optional: connect to external vector DB
# CHROMADB_URL=http://localhost:8000

# --- Translation ---
# Uses LibreTranslate (free, self-hostable)
LIBRETRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_API_KEY=

# --- Real-time Data ---
FINNHUB_API_KEY=           # Free tier: https://finnhub.io
NEWS_API_KEY=              # Free tier: https://newsapi.org

# --- App Configuration ---
NEXTAUTH_SECRET=your-secret-here
NEXT_PUBLIC_APP_NAME=Ultra Chatbot
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Admin ---
ADMIN_PASSWORD=changeme

# --- Encryption ---
ENCRYPTION_KEY=32-byte-hex-key-here
